#include <iostream>
using namespace std;

int main(){ 
    
    
    int numero, contador = 0;

    cout << "Ingrese un numero entero positivo: ";
    cin >> numero;
    cout << "La trayectoria de Collatz es: " << numero << " ";
    
    while (numero != 1) {
        
        if (numero % 2 == 0) {
            numero = numero / 2;
            cout << numero << " ";
            contador++;
        } 
        else {
            numero = 3 * numero + 1;
            cout << numero << " ";
            contador++;
        }
    }

    cout << "\nNumero de pasos: " << contador << endl;

    return 0;
}